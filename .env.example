# Baby Bean — environment variables
# Copy to .env and fill in. Real values set by P0-2 (Supabase schema task).
# EXPO_PUBLIC_ vars are exposed to the client bundle; only put publishable keys here.

# Supabase (from `supabase start` output for local dev, or your hosted project settings)
EXPO_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Server-only secrets (never prefixed EXPO_PUBLIC_; used by edge functions / scripts)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
